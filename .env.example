# ── Required for AI features ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── Optional: audio transcription ────────────────────────────────────────────
OPENAI_API_KEY=

# ── Canvas LMS ────────────────────────────────────────────────────────────────
CANVAS_API_TOKEN=
CANVAS_API_URL=

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_TOKEN=

# ── Readwise ──────────────────────────────────────────────────────────────────
READWISE_API_TOKEN=

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Google Suite (Calendar, Gmail, Drive) ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Pocket ────────────────────────────────────────────────────────────────────
POCKET_CONSUMER_KEY=
POCKET_ACCESS_TOKEN=

# ── Trakt ─────────────────────────────────────────────────────────────────────
TRAKT_CLIENT_ID=
TRAKT_USERNAME=

# ── Spotify ───────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Whoop ─────────────────────────────────────────────────────────────────────
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ── Twitter/X (optional — live tweet feeds) ───────────────────────────────────
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=

# ── Personal milestones ───────────────────────────────────────────────────────
DATADOG_START_DATE=2026-07-06

# ── Data directory (defaults to ~/.neuron locally, /data in Docker) ───────────
# JIMMY_DATA_DIR=/data
